# Токен от @BotFather
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz

# ID канала или чата для публикации (например -1001234567890)
TELEGRAM_CHAT_ID=-1001234567890

# User-Agent для HH.ru API (обязателен по правилам сервиса)
HH_USER_AGENT=ProductDesignerVacancyBot/1.0 (your@email.com)

# Опционально: access_token приложения HH.ru из https://dev.hh.ru/admin
HH_ACCESS_TOKEN=

# Часовой пояс для ежедневной рассылки в 12:00
TIMEZONE=Europe/Moscow

# Публиковать только вакансии, опубликованные не раньше чем N часов назад
MAX_VACANCY_AGE_HOURS=72
