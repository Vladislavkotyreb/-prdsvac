[Unit]
Description=Telegram Vacancy Bot
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=ubuntu
Group=ubuntu
WorkingDirectory=/home/ubuntu/vacancy-bot
Environment=PYTHONUNBUFFERED=1
ExecStart=/home/ubuntu/vacancy-bot/.venv/bin/python -m bot.main
Restart=always
RestartSec=10

[Install]
WantedBy=multi-user.target
